<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Contact Us | CA Services</title>
  <meta name="description" content="Contact our Indore-based CA firm for financial advisory, taxation, audit, registration, and compliance support." />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="<%= siteUrl %>/contact" />
  <meta property="og:title" content="Contact Us | CA Services" />
  <meta property="og:description" content="Reach our Indore office or submit a lead enquiry for professional CA services." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="<%= siteUrl %>/contact" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            corporate: '#0B2545'
          },
          boxShadow: {
            soft: '0 12px 40px rgba(11, 37, 69, 0.08)'
          }
        }
      }
    }
  </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "CA Services",
      "url": "<%= siteUrl %>/contact",
      "telephone": "<%= contactInfo.phone %>",
      "email": "<%= contactInfo.email %>",
      "image": "<%= siteUrl %>/",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "<%= contactInfo.streetAddress %>",
        "addressLocality": "<%= contactInfo.locality %>",
        "addressRegion": "<%= contactInfo.region %>",
        "postalCode": "<%= contactInfo.postalCode %>",
        "addressCountry": "<%= contactInfo.country %>"
      },
      "openingHoursSpecification": [{
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
        "opens": "10:00",
        "closes": "19:00"
      }],
      "areaServed": "Indore, Madhya Pradesh, India"
    }
  </script>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="bg-slate-50 text-slate-900" style="background:#f4f7fb;color:#10233d;" data-supabase-url="<%= supabase?.url || '' %>" data-supabase-anon-key="<%= supabase?.anonKey || '' %>">
  <header class="site-header">
    <div class="container header-inner">
      <div class="brand">
        <h1>CA Services</h1>
        <p class="tag">Professional Financial, Taxation, Audit & Compliance Solutions</p>
      </div>
      <button class="menu-btn" aria-label="Open menu">☰</button>
      <nav class="main-nav">
        <a href="/" class="nav-pill">Home</a>
        <a href="/services" class="nav-pill">Services</a>
        <a href="/blogs" class="nav-pill">Blogs</a>
        <a href="/contact" class="nav-pill" aria-current="page">Contact</a>
      </nav>
      <nav class="mobile-nav" aria-hidden="true">
        <a href="/" class="nav-pill">Home</a>
        <a href="/services" class="nav-pill">Services</a>
        <a href="/blogs" class="nav-pill">Blogs</a>
        <a href="/contact" class="nav-pill" aria-current="page">Contact</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="py-10 sm:py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <span class="eyebrow text-slate-50">Contact Us</span>
          <h2 class="mt-4 text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">Let’s discuss the right solution for your business</h2>
          <p class="mt-4 text-base leading-7 text-slate-600">Visit our Indore office or submit a quick enquiry form. We’ll review your details and respond promptly.</p>
        </div>

        <div class="mt-12 grid gap-8 lg:grid-cols-[0.92fr_1.08fr]">
          <aside class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-8 shadow-soft">
            <div class="space-y-6">
              <div class="flex items-start gap-4 rounded-2xl bg-slate-50 p-4 ring-1 ring-slate-100">
                <div class="flex h-12 w-12 flex-none items-center justify-center rounded-2xl bg-white text-[#0B2545] shadow-sm ring-1 ring-slate-100">
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 21s6-5.1 6-10.2A6 6 0 0 0 6 10.8C6 15.9 12 21 12 21Z" />
                    <circle cx="12" cy="10.5" r="2" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Office Address</p>
                  <address class="mt-1 not-italic text-sm leading-6 text-slate-700">
                    <%= contactInfo.officeName %><br />
                    <%= contactInfo.streetAddress %><br />
                    <%= contactInfo.locality %>, <%= contactInfo.region %> <%= contactInfo.postalCode %><br />
                    <%= contactInfo.country %>
                  </address>
                </div>
              </div>

              <div class="grid gap-4 sm:grid-cols-2">
                <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                  <div class="flex items-center gap-3">
                    <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-white text-[#0B2545] shadow-sm ring-1 ring-slate-100">
                      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.7-3.1 19.3 19.3 0 0 1-6-6A19.8 19.8 0 0 1 1 4.2 2 2 0 0 1 3 2h3a2 2 0 0 1 2 1.7c.1.9.4 1.8.8 2.6a2 2 0 0 1-.4 2.1L7 9.9a16 16 0 0 0 6.9 6.9l1.5-1.4a2 2 0 0 1 2.1-.4c.8.4 1.7.7 2.6.8A2 2 0 0 1 22 16.9Z" />
                      </svg>
                    </div>
                    <div>
                      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Phone</p>
                      <a class="mt-1 block text-sm font-medium text-slate-900" href="tel:<%= contactInfo.phone.replace(/\s+/g, '') %>"><%= contactInfo.phone %></a>
                    </div>
                  </div>
                </div>

                <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                  <div class="flex items-center gap-3">
                    <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-white text-[#0B2545] shadow-sm ring-1 ring-slate-100">
                      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M4 4h16v16H4z" />
                        <path d="m4 7 8 6 8-6" />
                      </svg>
                    </div>
                    <div>
                      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Email</p>
                      <a class="mt-1 block text-sm font-medium text-slate-900" href="mailto:<%= contactInfo.email %>"><%= contactInfo.email %></a>
                    </div>
                  </div>
                </div>
              </div>

              <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                <div class="flex items-start gap-3">
                  <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-white text-[#0B2545] shadow-sm ring-1 ring-slate-100">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <circle cx="12" cy="12" r="9" />
                      <path d="M12 7v5l3 2" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Working Hours</p>
                    <p class="mt-1 text-sm leading-6 text-slate-700"><%= contactInfo.workingHours %></p>
                    <p class="mt-2 text-sm text-slate-500">Response time: within one business day.</p>
                  </div>
                </div>
              </div>

              <div class="rounded-2xl bg-[#0B2545] p-5 text-white shadow-soft">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/70">Why contact us</p>
                <p class="mt-2 text-sm leading-6 text-white/85">Professional guidance for financial consultancy, taxation, audit, registration, and business advisory needs.</p>
              </div>
            </div>
          </aside>

          <section id="lead-form" class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-8 shadow-soft">
            <div class="flex flex-wrap items-start justify-between gap-4 border-b border-slate-100 pb-5">
              <div>
                <span class="eyebrow">Quick Enquiry Form</span>
                <h3 class="mt-3 text-2xl font-semibold tracking-tight text-slate-900">Send your requirement</h3>
                <p class="mt-2 text-sm leading-6 text-slate-600">Share the basics and we’ll get back with the right next step.</p>
              </div>
              <div class="rounded-2xl bg-slate-50 px-4 py-3 text-sm text-slate-600 ring-1 ring-slate-100">
                <span class="block text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Inquiry Count</span>
                <span class="mt-1 block text-lg font-semibold text-slate-900"><%= inquiryCount %></span>
              </div>
            </div>

            <% if (submitted) { %>
              <div class="mt-5 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800" role="status">Thanks! Your inquiry has been received. We’ll contact you soon.</div>
            <% } %>
            <% if (error) { %>
              <div class="mt-5 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800" role="alert">Please enter your full name and a valid 10-digit phone number.</div>
            <% } %>
            <% if (errorMsg) { %>
              <div class="mt-5 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800" role="alert"><strong>Error:</strong> <%= errorMsg %></div>
            <% } %>

            <form class="inquiry-form hero-inquiry-form mt-6" action="/inquiry" method="POST" data-validate="lead" novalidate>
              <input type="hidden" name="redirectTo" value="/contact#lead-form" />
              <div class="grid gap-4 sm:grid-cols-2">
                <label class="field">
                  <span>Full Name *</span>
                  <input type="text" name="name" placeholder="Your name" required autocomplete="name" />
                </label>
                <label class="field">
                  <span>Email</span>
                  <input type="email" name="email" placeholder="name@example.com" autocomplete="email" />
                </label>
                <label class="field">
                  <span>Phone *</span>
                  <input type="tel" name="phone" placeholder="9876543210" inputmode="numeric" pattern="^[0-9]{10}$" minlength="10" maxlength="10" required autocomplete="tel" />
                </label>
                <label class="field">
                  <span>Service</span>
                  <select name="service">
                    <option value="">Select service</option>
                    <% services.forEach(function(item){ %>
                      <option value="<%= item.title %>"><%= item.title %></option>
                    <% }) %>
                    <option value="Other">Other</option>
                  </select>
                </label>
              </div>

              <div class="mt-4">
                <label class="field">
                  <span>Message</span>
                  <textarea name="message" rows="5" placeholder="Tell us what you need"></textarea>
                </label>
              </div>

              <div class="mt-6 flex flex-wrap items-center gap-4">
                <button class="btn primary submit-btn" type="submit">
                  <span>Send Inquiry</span>
                  <span class="spinner" aria-hidden="true"></span>
                </button>
                <p class="form-note text-sm">We have received <strong><%= inquiryCount %></strong> inquiry(ies) so far.</p>
              </div>
            </form>
          </section>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container">&copy; <%= new Date().getFullYear() %> CA Services</div>
  </footer>
  <script src="/js/main.js"></script>
</body>
</html>

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Admin Blog Manager | CA Services</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body data-supabase-url="<%= supabase?.url || '' %>" data-supabase-anon-key="<%= supabase?.anonKey || '' %>">
  <header class="site-header">
    <div class="container header-inner">
      <div class="brand">
        <h1>CA Services</h1>
        <p class="tag">Blog Admin</p>
      </div>
      <nav class="main-nav">
        <a href="/" class="nav-pill">Home</a>
        <a href="/blogs" class="nav-pill">Blogs</a>
        <a href="/contact" class="nav-pill">Contact</a>
      </nav>
    </div>
  </header>

  <main class="container admin-layout">
    <section class="admin-hero reveal-card">
      <span class="eyebrow">Admin</span>
      <h2>Manage blog posts from one place.</h2>
      <p>Use this page to create, update, or soft delete blog posts. If Supabase is connected, actions go through your blog RPC; otherwise the local fallback keeps the demo usable.</p>
      <div class="admin-notes">
        <span class="status-pill <%= supabaseConfigured ? 'status-ok' : 'status-warn' %>"><%= supabaseConfigured ? 'Supabase connected' : 'Local fallback active' %></span>
        <span class="status-pill <%= blogAdminConfigured ? 'status-ok' : 'status-warn' %>"><%= blogAdminConfigured ? 'Admin auth enabled' : 'Admin auth missing' %></span>
      </div>
    </section>

    <% if (success) { %>
      <div class="notice notice-success"><%= success %></div>
    <% } %>
    <% if (error) { %>
      <div class="notice notice-error"><%= error %></div>
    <% } %>

    <section class="admin-grid">
      <form class="admin-form reveal-card" action="/admin/blogs/save" method="POST">
        <span class="eyebrow">New Post</span>
        <h3>Create a blog post</h3>
        <input type="hidden" name="blog_id" value="" />
        <label class="field">
          <span>Title *</span>
          <input type="text" name="title" placeholder="Blog title" required />
        </label>
        <label class="field">
          <span>Slug</span>
          <input type="text" name="slug" placeholder="optional-custom-slug" />
        </label>
        <label class="field">
          <span>Category</span>
          <input type="text" name="category" placeholder="Taxation / Audit / Registration" />
        </label>
        <label class="field">
          <span>Status</span>
          <select name="status">
            <option>Draft</option>
            <option>Published</option>
          </select>
        </label>
        <label class="field">
          <span>Summary</span>
          <textarea name="summary" rows="3" placeholder="Short preview text"></textarea>
        </label>
        <label class="field">
          <span>Content *</span>
          <textarea name="content" rows="8" placeholder="Full article text" required></textarea>
        </label>
        <button class="btn primary" type="submit">Save Post</button>
      </form>

      <div class="admin-list">
        <% if (blogs.length) { %>
          <% blogs.forEach(function(blog){ %>
            <article class="admin-card reveal-card">
              <div class="admin-card-head">
                <div>
                  <span class="blog-chip"><%= blog.category %></span>
                  <h3><%= blog.title %></h3>
                  <p><%= blog.slug %></p>
                </div>
                <span class="status-pill <%= blog.status === 'Published' ? 'status-ok' : 'status-warn' %>"><%= blog.status %></span>
              </div>
              <form class="admin-edit" action="/admin/blogs/save" method="POST">
                <input type="hidden" name="blog_id" value="<%= blog.id %>" />
                <label class="field">
                  <span>Title</span>
                  <input type="text" name="title" value="<%= blog.title %>" required />
                </label>
                <label class="field">
                  <span>Slug</span>
                  <input type="text" name="slug" value="<%= blog.slug %>" />
                </label>
                <label class="field">
                  <span>Category</span>
                  <input type="text" name="category" value="<%= blog.category %>" />
                </label>
                <label class="field">
                  <span>Status</span>
                  <select name="status">
                    <option <%= blog.status === 'Draft' ? 'selected' : '' %>>Draft</option>
                    <option <%= blog.status === 'Published' ? 'selected' : '' %>>Published</option>
                  </select>
                </label>
                <label class="field">
                  <span>Summary</span>
                  <textarea name="summary" rows="3"><%= blog.summary %></textarea>
                </label>
                <label class="field">
                  <span>Content</span>
                  <textarea name="content" rows="8" required><%= blog.content %></textarea>
                </label>
                <div class="admin-actions">
                  <button class="btn primary" type="submit">Update</button>
                </div>
              </form>
              <form action="/admin/blogs/delete" method="POST" class="admin-delete">
                <input type="hidden" name="blog_id" value="<%= blog.id %>" />
                <button class="btn" type="submit" onclick="return confirm('Delete this blog post?')">Soft Delete</button>
              </form>
            </article>
          <% }) %>
        <% } else { %>
          <div class="blog-empty reveal-card">
            <h3>No blog posts found.</h3>
            <p>Create your first post from the form on the left.</p>
          </div>
        <% } %>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container">&copy; <%= new Date().getFullYear() %> CA Services</div>
  </footer>
  <script src="/js/main.js"></script>
</body>
</html>
